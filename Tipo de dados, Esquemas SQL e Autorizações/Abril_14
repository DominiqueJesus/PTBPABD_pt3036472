/* Na atividade do dia 17 de março eu não crei a view grade_points para solucionar meu exercício,
então criei ela nesse mesmo script */

CREATE VIEW grade_points AS 
(SELECT t.grade,
	CASE 
        WHEN t.grade = 'A+' THEN 4
		WHEN t.grade = 'A'THEN 3.7
		WHEN t.grade = 'A-' THEN 3.3
		WHEN t.grade = 'B+' THEN 3
		WHEN t.grade = 'B' THEN 2.7
		WHEN t.grade = 'B-' THEN 2.3
		WHEN t.grade = 'C+' THEN 2
		WHEN t.grade = 'C' THEN 1.7
        ELSE 1.3
     END AS points
FROM Student_PT3036472.takes t
GROUP BY grade);

/* Questão 01. O User_B poderá selecionar todos os atributos da relação INSTRUCTOR e TAKES,
exceto salary e grade, respectivamente.
IMPORTANTE: O User_B foi criado na avaliação contínua anterior. */

CREATE VIEW instructor_B AS
(SELECT ID, name, dept_name
FROM Student_PT3036472.instructor);

CREATE VIEW takes_B AS
(SELECT ID, course_id, sec_id, semester, year
FROM Student_PT3036472.takes);

GRANT SELECT ON instructor_B TO User_B;
GRANT SELECT ON takes_B TO User_B;

/* Questão 02. O User_C poderá selecionar ou modificar a relação SECTION, 
mas só poderá recuperar e modificar os atributos course_id, sec_id, semester e year.
IMPORTANTE: O User_C foi criado na avaliação contínua anterior. */

CREATE VIEW section_C AS
(SELECT course_id, sec_id, semester, year
FROM Student_PT3036472.section);

GRANT SELECT, UPDATE ON section_C TO User_C;

/* Questão 03. O User_D poderá selecionar qualquer atributo das relações INSTRUCTOR e STUDENT. 
